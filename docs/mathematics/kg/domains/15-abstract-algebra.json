      ],
      "requires": [
        "math.abst.group-theory"
      ],
      "unlocks": [
        "math.abst.alternating-group"
      ],
      "related": [],
      "cross_links": [],
      "description": "S\u2099 = all bijections on {1,\u2026,n}; |S\u2099|=n!. Every finite group embeds in S\u2099 (Cayley's theorem). Cycle notation; cycle structure determines conjugacy class. Transpositions generate S\u2099.",
      "difficulty": "advanced",
      "estimated_hours": 5,
      "bloom": "apply",
      "mastery_threshold": 0.85,
      "references": [
        "Dummit & Foote, Abstract Algebra, \u00a71.3"
      ]
    },
    {
      "id": "math.abst.alternating-group",
      "name": "Alternating Group",
      "aliases": [
        "A\u2099",
        "even permutation"
      ],
      "parent": "math.abst.symmetric-group",
      "children": [],
      "requires": [
        "math.abst.symmetric-group",
        "math.abst.normal-subgroup"
      ],
      "unlocks": [],
      "related": [],
      "cross_links": [],
      "description": "A\u2099 = even permutations (product of even number of transpositions); |A\u2099|=n!/2. A normal subgroup of S\u2099. For n\u22655, A\u2099 is simple (no proper normal subgroups). Simplicity of A\u2085 implies quintic is not solvable by radicals.",
      "difficulty": "expert",
      "estimated_hours": 5,
      "bloom": "analyze",
      "mastery_threshold": 0.8,
      "references": [
        "Dummit & Foote, Abstract Algebra, \u00a74.6"
      ]
    },
    {
      "id": "math.abst.ring-theory",
