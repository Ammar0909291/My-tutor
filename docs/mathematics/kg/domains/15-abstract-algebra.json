    {
      "id": "math.abst.quotient-ring",
      "name": "Quotient Ring",
      "aliases": [
        "factor ring",
        "residue ring",
        "R/I"
      ],
      "parent": null,
      "children": [],
      "requires": [
        "math.abst.ideal"
      ],
      "unlocks": [],
      "related": [],
      "cross_links": [],
      "description": "R/I = {r+I : r\u2208R} with (r+I)+(s+I)=(r+s)+I and (r+I)(s+I)=rs+I. Analogue of quotient groups. First isomorphism theorem for rings: if \u03c6:R\u2192S is a ring homomorphism, R/ker(\u03c6)\u2245im(\u03c6).",
      "difficulty": "expert",
      "estimated_hours": 4,
      "bloom": "apply",
