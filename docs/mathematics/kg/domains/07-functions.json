      "parent": null,
      "children": [],
      "requires": ["math.func.function-concept"],
      "unlocks": ["math.func.bijection"],
      "related": ["math.func.injectivity"],
      "cross_links": [],
      "description": "f: A → B is surjective if every b ∈ B has at least one a ∈ A with f(a) = b; the range equals the codomain.",
      "difficulty": "proficient",
      "estimated_hours": 3,
      "bloom": "understand",
      "mastery_threshold": 0.80,
      "references": ["NCERT Grade 12", "Epp 2011"]
    },
