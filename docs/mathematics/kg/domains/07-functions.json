      "unlocks": ["math.func.inverse-functions"],
      "related": ["math.func.surjectivity", "math.func.bijection"],
      "cross_links": [],
      "description": "f is injective if f(a) = f(b) implies a = b; different inputs give different outputs; passes the horizontal line test.",
      "difficulty": "proficient",
      "estimated_hours": 3,
      "bloom": "understand",
      "mastery_threshold": 0.80,
      "references": ["NCERT Grade 12", "Epp 2011", "OpenStax College Algebra"]
