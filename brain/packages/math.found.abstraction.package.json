  "assets": [
    {
      "assetId": "math.found.abstraction/learning_objective/1",
      "kind": "learning_objective",
      "conceptId": "math.found.abstraction",
      "title": "Learning Objective",
      "content": "**Mastery statement:** A student who achieves mastery demonstrates that abstraction is the process of identifying essential properties shared across different contexts while ignoring irrelevant surface details; can identify what has been abstracted away in a given example; can apply the same abstract reasoning to a new, structurally identical situation; and can explain WHY abstraction is useful in mathematics.\n\n**NOT mastery:** A student who can say \"abstraction means ignoring details\" without being able to identify WHICH details are essential vs. irrelevant, or who cannot transfer an abstract rule to a new context, has NOT achieved mastery.\n\n---",
      "localKey": null,
      "language": "en",
      "refs": [],
      "span": {
