generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations and db push connect directly (Neon: the non-pooled URL).
  // The app itself always uses the pooled DATABASE_URL above.
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth v5 required tables) ───────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  onboardingCompleted Boolean   @default(false)
  xpPoints            Int       @default(0)
  referralCode        String?   @unique
  referredBy          String?
  freeSessionsExtra   Int       @default(0)
  telegramChatId      String?
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts                 Account[]
  sessions                 AuthSession[]
  profile                  Profile?
  learnSessions            LearnSession[]
  subscription             Subscription?
  payments                 Payment[]
  learningPaths            LearningPath[]
  flashcards               Flashcard[]
  studentProgress          StudentProgress[]
  finalAssessmentResults   FinalAssessmentResult[]
  subjectCertificates      SubjectCertificate[]
  referralsGiven           Referral[]                @relation("referrer")
  weeklyXP                 WeeklyXP[]
  assessmentResults        AssessmentResult[]
  subjectAssessmentResults SubjectAssessmentResult[]
  coachProfile             CoachProfile?
  assessmentAttempts       AssessmentAttempt[]
  moduleProgress           ModuleProgress[]
  topicProgress            TopicProgress[]

  learningAnalytics  LearningAnalytics?
  learningProfile    LearningProfile?
  subjectAnalytics   SubjectAnalytics[]
  retentionMetrics   RetentionMetric[]
  studySessions      StudySession[]
  performanceMetrics PerformanceMetric[]
  coachInsights      CoachInsight[]
  yandexUsageLogs    YandexUsageLog[]

  reviewSchedules     ReviewSchedule[]
  reviewAttempts      ReviewAttempt[]
  projectSubmissions  ProjectSubmission[]
  knowledgeRetentions KnowledgeRetention[]

  roadmapEnrollments  RoadmapEnrollment[]
  milestones          Milestone[]
  capstoneSubmissions CapstoneSubmission[]
  certificates        Certificate[]
  careerProfile       CareerProfile?
  jobReadiness        JobReadiness?

  xpTransactions    XpTransaction[]
  userLevel         UserLevel?
  userAchievements  UserAchievement[]
  studyStreak       StudyStreak?
  challengeProgress ChallengeProgress[]
  activityLogs      ActivityLog[]
  socialProfile     SocialProfile?
  clientEvents      ClientEvent[]
  pushSubscriptions PushSubscription[]

  emailVerificationTokens EmailVerificationToken[]

  guardianLinksAsStudent  GuardianLink[]       @relation("GuardianLinkStudent")
  guardianLinksAsGuardian GuardianLink[]       @relation("GuardianLinkGuardian")
  teacherNotesAuthored    TeacherNote[]        @relation("TeacherNoteAuthor")
  teacherNotesReceived    TeacherNote[]        @relation("TeacherNoteRecipient")
  organizationsOwned      Organization[]       @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[] @relation("OrganizationMembership")
  evidenceRecords         EvidenceRecord[]
  practiceSessions        PracticeSession[]
  mistakeRecords          MistakeRecord[]
  learningCheckpoints     LearningCheckpoint[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ─── Student Profile ──────────────────────────────────────────────────────────

enum UserType {
  GENERAL_LEARNER
  SCHOOL_STUDENT
}

model Profile {
  id               String           @id @default(cuid())
  userId           String           @unique
  displayName      String
  selfDescription  String           @db.Text
  // School Mode (Sprint BF): set once at onboarding; board/grade stay null for
  // general learners. educationBoard holds a board id from the education
  // registry ('cbse', 'up_board', ...) — validated in the API layer.
  userType         UserType         @default(GENERAL_LEARNER)
  educationBoard   String?
  grade            Int?
  currentLevel     String?
  targetLevel      String?
  learningGoals    String?          @db.Text
  voiceId          String?
  speechRate       Float            @default(1.0)
  teachingLanguage TeachingLanguage @default(en)
  country          String           @default("global")
  voiceSpeed       Float            @default(1.0)
  confusedTopics   String[]         @default([])
  masteredTopics   String[]         @default([])
  totalSessions    Int              @default(0)
  totalMessages    Int              @default(0)
  lastStudiedTopic String?
  streakDays       Int              @default(0)
  lastStudyDate    DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects ProfileSubject[]

  @@map("profiles")
}

// ─── Subjects ─────────────────────────────────────────────────────────────────

model Subject {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  // c | cpp | python | english
  type        SubjectType
  description String?     @db.Text

  profileSubjects ProfileSubject[]
  learnSessions   LearnSession[]
  learningPaths   LearningPath[]
  assessments     SubjectAssessment[]
  learningGoals   LearningGoal[]
  moduleProgress  ModuleProgress[]

  subjectAnalytics   SubjectAnalytics[]
  retentionMetrics   RetentionMetric[]
  studySessions      StudySession[]
  performanceMetrics PerformanceMetric[]
  coachInsights      CoachInsight[]

  reviewSchedules     ReviewSchedule[]
  projects            Project[]
  knowledgeRetentions KnowledgeRetention[]

  @@map("subjects")
}

model ProfileSubject {
  id        String   @id @default(cuid())
  profileId String
  subjectId String
  level     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  // Per-subject independent tracking — each enrolled subject keeps its own
  // level/target/progress/estimate, separate from the legacy single
  // Profile.currentLevel (which now only reflects the user's "primary" subject).
  // Level system: 0 Complete Beginner · 1 Beginner · 2 Intermediate
  //               3 Advanced · 4 Professional · 5 Expert
  currentLevelIndex  Int      @default(0)
  targetLevelIndex   Int?
  progressPercent    Int      @default(0)
  estimatedHoursLeft Int?
  isActive           Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([profileId, subjectId])
  @@map("profile_subjects")
}

// ─── Assessments (per-subject quizzes / exams / mastery checks) ──────────────

model SubjectAssessment {
  id         String         @id @default(cuid())
  subjectId  String
  kind       AssessmentKind @default(LESSON_QUIZ)
  levelIndex Int            @default(0)
  moduleSlug String
  title      String
  // Array of { question, options, correctIndex, explanation }
  questions  Json
  passScore  Int            @default(70)
  createdAt  DateTime       @default(now())

  subject Subject                   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  results SubjectAssessmentResult[]

  @@unique([subjectId, moduleSlug])
  @@index([subjectId, levelIndex, moduleSlug])
  @@map("subject_assessments")
}

model SubjectAssessmentResult {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String
  score        Int
  passed       Boolean
  // Learner's submitted answers, for review
  answers      Json?
  createdAt    DateTime @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment SubjectAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId, assessmentId])
  @@map("subject_assessment_results")
}

// ─── Module Progress (per-subject curriculum-tree progression / unlocking) ───
// Tracks the learner's progress through SUBJECT_LIBRARY curriculum modules,
// independently per enrolled subject. Status drives the unlock chain:
// COMPLETED → next module becomes AVAILABLE → ... → rest stay LOCKED.

model ModuleProgress {
  id          String       @id @default(cuid())
  userId      String
  subjectId   String
  moduleSlug  String
  status      ModuleStatus @default(LOCKED)
  masteryPct  Int          @default(0)
  bestScore   Int?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId, moduleSlug])
  @@index([userId, subjectId])
  @@map("module_progress")
}

enum ModuleStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

// ─── Topic Progress (knowledge-graph node tracking) ──────────────────────────

model TopicProgress {
  id             String      @id @default(cuid())
  userId         String
  subjectSlug    String
  topicSlug      String
  status         TopicStatus @default(NOT_STARTED)
  masteryPct     Int         @default(0)
  attempts       Int         @default(0)
  lastScore      Int?
  completedAt    DateTime?
  revisionCount  Int         @default(0)
  lastRevisionAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectSlug, topicSlug])
  @@index([userId, subjectSlug])
  @@map("topic_progress")
}

enum TopicStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  MASTERED
  SKIPPED
  REVISION
}

// ─── Evidence Records (Sprint M — Assessment Integrity) ──────────────────────

enum EvidenceType {
  QUIZ
  PRACTICE
  PROJECT
  REVIEW
  ASSESSMENT
}

model EvidenceRecord {
  id          String       @id @default(cuid())
  userId      String
  subjectSlug String
  topicSlug   String
  type        EvidenceType
  score       Float
  weight      Float        @default(1.0)
  method      String       @default("AI")
  notes       Json?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectSlug, topicSlug])
  @@map("evidence_records")
}

model PracticeSession {
  id          String    @id @default(cuid())
  userId      String
  subjectSlug String
  topicSlug   String
  // Sprint BM: school chapter practice; null for legacy topic-level sessions
  chapterId   String?
  // Sprint BN: "practice" (default) | "assessment"
  kind        String    @default("practice")
  questions   Json      // StoredPracticeQuestion[] — includes correct answers (never sent to client)
  completedAt DateTime?
  score       Int?      // 0-100
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectSlug, topicSlug])
  @@index([userId, chapterId])
  @@map("practice_sessions")
}

model MistakeRecord {
  id          String   @id @default(cuid())
  userId      String
  subjectSlug String
  topicSlug   String   // topic being practiced
  sessionId   String   // PracticeSession id
  category    String   // mistake category from taxonomy (e.g. "arithmetic_error")
  questionId  String   // question id within session
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectSlug])
  @@index([userId, subjectSlug, topicSlug])
  @@index([userId, subjectSlug, category])
  @@map("mistake_records")
}

// Sprint BS: lightweight in-session understanding checks — micro-checkpoints
// the tutor asks while teaching, evaluated by a lightweight AI classifier.
// Not part of the Practice/Assessment systems.
model LearningCheckpoint {
  id          String   @id @default(cuid())
  userId      String
  board       String
  grade       Int
  subjectSlug String
  chapterId   String
  kgNodeId    String?
  question    String
  answer      String
  userResponse String
  passed      Boolean
  hintUsed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, subjectSlug, chapterId])
  @@index([userId, subjectSlug, createdAt])
  @@map("learning_checkpoints")
}

// ─── Learning Path (Claude-generated curriculum) ─────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  title       String
  // Full JSON curriculum generated by Claude
  curriculum  Json
  currentStep Int      @default(0)
  totalSteps  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@index([userId, subjectId])
  @@map("learning_paths")
}

// ─── Learn Sessions ───────────────────────────────────────────────────────────

model LearnSession {
  id              String        @id @default(cuid())
  userId          String
  subjectId       String
  title           String?
  status          SessionStatus @default(ACTIVE)
  // Snapshot of context sent to Claude at session start
  contextSnapshot Json?
  // Detected mood/engagement level from Claude's analysis
  moodAnalysis    Json?
  summary         String?       @db.Text
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  updatedAt       DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject  Subject   @relation(fields: [subjectId], references: [id])
  messages Message[]

  @@index([userId, subjectId])
  @@index([userId, status])
  @@map("learn_sessions")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id           String      @id @default(cuid())
  sessionId    String
  role         MessageRole
  content      String      @db.Text
  // If voice: transcript + audio file reference
  audioUrl     String?
  // If code: language + snippet
  codeSnippet  String?     @db.Text
  codeLanguage String?
  // Token usage for cost tracking
  inputTokens  Int?
  outputTokens Int?
  createdAt    DateTime    @default(now())

  session LearnSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  plan              String    @default("free") // free | basic | pro | annual
  planExpiresAt     DateTime?
  lessonsThisMonth  Int       @default(0)
  monthResetAt      DateTime  @default(now())
  // YooKassa payment tracking
  yookassaPaymentId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Payment Records ──────────────────────────────────────────────────────────

model Payment {
  id         String   @id @default(cuid())
  userId     String
  yookassaId String   @unique
  plan       String // basic | pro | annual
  amount     Int // in kopecks
  currency   String   @default("RUB")
  status     String   @default("pending") // pending | succeeded | canceled
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Flashcards ───────────────────────────────────────────────────────────────

model Flashcard {
  id            String    @id @default(cuid())
  userId        String
  topic         String
  question      String
  answer        String
  nextReview    DateTime  @default(now())
  reviewCount   Int       @default(0)
  easy          Boolean   @default(false)
  lastReviewedAt DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Sprint AP: /api/flashcards filters by (userId, nextReview) for due cards
  // and (userId, lastReviewedAt) for the studied-today count on every load.
  @@index([userId, nextReview])
  @@index([userId, lastReviewedAt])
  @@map("flashcards")
}

// ─── Structured Curriculum ───────────────────────────────────────────────────

model Curriculum {
  id          String   @id @default(cuid())
  subjectCode String   // subject slug: c, cpp, python, english, javascript, typescript, russian, etc.
  unit        Int
  unitTitle   String
  lesson      Int // lesson number within unit
  lessonTitle String
  lessonGoal  String   @db.Text
  order       Int // global order across all lessons in subject
  topicSlug   String?  // KG node slug — links this lesson to the knowledge graph
  createdAt   DateTime @default(now())

  @@unique([subjectCode, order])
  @@index([subjectCode])
  @@map("curriculum")
}

model StudentProgress {
  id                String   @id @default(cuid())
  userId            String
  subjectCode       String
  currentLesson     Int      @default(1)
  completedLessons  Int[]    @default([])
  lastStudiedAt     DateTime @default(now())
  lastLessonTitle   String?
  lastUnitTitle     String?
  // Sprint N — subject completion tracking
  isCompleted       Boolean  @default(false)
  completedAt       DateTime?
  completionPercent Int      @default(0)
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectCode])
  @@map("student_progress")
}

// ─── Sprint N — Final Assessment & Subject Certificates ──────────────────────

model FinalAssessmentResult {
  id             String   @id @default(cuid())
  userId         String
  subjectCode    String
  score          Int
  totalQuestions Int
  passed         Boolean
  takenAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectCode])
  @@map("final_assessment_results")
}

model SubjectCertificate {
  id              String   @id @default(cuid())
  userId          String
  subjectCode     String
  subjectName     String
  certificateCode String   @unique
  recipientName   String
  totalLessons    Int
  score           Int
  issuedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectCode])
  @@map("subject_certificates")
}

// ─── Curriculum Assessments (module gating) ──────────────────────────────────

model Assessment {
  id           String         @id @default(cuid())
  subjectCode  String // 'python' | 'c' | 'cpp' | 'english' | ...
  levelBand    String // 'beginner' | 'intermediate' | 'advanced' | 'professional' | 'expert'
  moduleIndex  Int // position of the module within the level band
  moduleTitle  String
  type         AssessmentType @default(QUIZ)
  passingScore Int            @default(70) // percentage required to pass

  results AssessmentResult[]

  @@unique([subjectCode, levelBand, moduleIndex])
  @@index([subjectCode])
  @@map("assessments")
}

model AssessmentResult {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String
  score        Int // percentage 0-100
  passed       Boolean
  masteryPct   Int      @default(0)
  completedAt  DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId, assessmentId])
  @@map("assessment_results")
}

enum AssessmentType {
  QUIZ
  CHALLENGE
  PROJECT
}

// ─── Coach: Placement Interview & Personalized Plan (Sprint 1, additive) ─────

model CoachProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningGoals LearningGoal[]

  @@map("coach_profiles")
}

model LearningGoal {
  id               String         @id @default(cuid())
  coachProfileId   String
  subjectId        String
  // Interview answers
  claimedLevel     LevelBand
  targetLevel      LevelBand
  reason           LearningReason
  dailyMinutes     Int
  // Recommendation produced after placement (or carried over from claimedLevel if skipped)
  recommendedLevel LevelBand?
  status           GoalStatus     @default(INTERVIEW)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  coachProfile CoachProfile         @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  subject      Subject              @relation(fields: [subjectId], references: [id])
  assessment   PlacementAssessment?
  estimate     LearningEstimate?
  commitment   StudyCommitment?

  @@unique([coachProfileId, subjectId])
  @@map("learning_goals")
}

model PlacementAssessment {
  id             String          @id @default(cuid())
  learningGoalId String          @unique
  subjectCode    String
  // Generated MCQ questions: [{question, options[], correctIndex, explanation, skill}]
  questions      Json
  status         PlacementStatus @default(PENDING)
  createdAt      DateTime        @default(now())

  learningGoal LearningGoal        @relation(fields: [learningGoalId], references: [id], onDelete: Cascade)
  attempts     AssessmentAttempt[]

  @@map("placement_assessments")
}

model AssessmentAttempt {
  id                    String    @id @default(cuid())
  placementAssessmentId String
  userId                String
  // Submitted answers: [{questionIndex, selectedIndex, correct}]
  answers               Json
  score                 Int // percentage 0-100
  recommendedLevel      LevelBand
  strengths             String[]  @default([])
  weaknesses            String[]  @default([])
  createdAt             DateTime  @default(now())

  placementAssessment PlacementAssessment @relation(fields: [placementAssessmentId], references: [id], onDelete: Cascade)
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("assessment_attempts")
}

model LearningEstimate {
  id              String   @id @default(cuid())
  learningGoalId  String   @unique
  estimatedHours  Int
  estimatedWeeks  Int
  estimatedMonths Int
  pathSummary     String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  learningGoal LearningGoal @relation(fields: [learningGoalId], references: [id], onDelete: Cascade)

  @@map("learning_estimates")
}

model StudyCommitment {
  id             String   @id @default(cuid())
  learningGoalId String   @unique
  dailyMinutes   Int
  label          String
  createdAt      DateTime @default(now())

  learningGoal LearningGoal @relation(fields: [learningGoalId], references: [id], onDelete: Cascade)

  @@map("study_commitments")
}

enum LevelBand {
  COMPLETE_BEGINNER
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
  EXPERT
}

enum LearningReason {
  CAREER
  JOB_CHANGE
  SCHOOL
  UNIVERSITY
  BUSINESS
  PERSONAL_INTEREST
}

enum GoalStatus {
  INTERVIEW
  PLACEMENT_OFFERED
  PLACEMENT_IN_PROGRESS
  PLACED
  PLAN_READY
}

enum PlacementStatus {
  PENDING
  COMPLETED
  SKIPPED
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id         String    @id @default(cuid())
  referrerId String
  referredId String?
  code       String    @unique
  used       Boolean   @default(false)
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id])

  @@map("referrals")
}

// ─── Weekly XP (leaderboard) ──────────────────────────────────────────────────

model WeeklyXP {
  id     String @id @default(cuid())
  userId String
  week   String // "2026-W23"
  xp     Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, week])
  @@map("weekly_xp")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeachingLanguage {
  ru
  en
  hi
}

enum SubjectType {
  C
  CPP
  PYTHON
  ENGLISH
  // Broad categories used by the multi-subject library (Subject Library) —
  // specific subjects within a category are distinguished by slug/name, not type.
  LANGUAGE
  PROGRAMMING
  MATHEMATICS
  PHYSICS
  CHEMISTRY
  BIOLOGY
  AI
}

enum AssessmentKind {
  LESSON_QUIZ
  MODULE_EXAM
  PRACTICAL
  MASTERY
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

