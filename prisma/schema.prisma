// ─── Sprint G: Learning Intelligence — guardian links (parent/teacher) ───────
// Read-only visibility into a student's learning data for a linked parent or
// teacher. The student creates an invite code; a guardian redeems it to form
// an ACTIVE link (and the student can revoke at any time). This adds no new
// write paths into core learning data — guardians only ever read aggregated
// reports. Teachers additionally get a separate TeacherNote channel below for
// goals/module recommendations, layered on top of (never editing) curriculum data.
enum GuardianRelationship {
  PARENT
  TEACHER
}

enum GuardianLinkStatus {
  PENDING
  ACTIVE
  REVOKED
}

model GuardianLink {
  id           String               @id @default(cuid())
  studentId    String
  guardianId   String?
  relationship GuardianRelationship
  status       GuardianLinkStatus   @default(PENDING)
  inviteCode   String               @unique
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  student  User  @relation("GuardianLinkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  guardian User? @relation("GuardianLinkGuardian", fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([guardianId, status])
  @@map("guardian_links")
}

enum TeacherNoteKind {
  GOAL
  MODULE_RECOMMENDATION
  NOTE
}

enum TeacherNoteStatus {
  ACTIVE
  COMPLETED
  DISMISSED
}

// Lightweight teacher → student channel for goals/module recommendations.
// Purely additive notes alongside existing curriculum/roadmap data — teachers
// never edit student records directly ("No direct database editing" in spec).
model TeacherNote {
  id          String            @id @default(cuid())
  teacherId   String
  studentId   String
  kind        TeacherNoteKind   @default(NOTE)
  subjectSlug String?
  title       String
  detail      String?           @db.Text
  status      TeacherNoteStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  teacher User @relation("TeacherNoteAuthor", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("TeacherNoteRecipient", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([teacherId, createdAt])
  @@map("teacher_notes")
}

// ─── Sprint G: Organization foundation (Part 7 — architecture only) ──────────
// Schools / training centers / corporate learning. Not multi-tenant yet — no
// data isolation or org-scoped queries elsewhere in the app. Just the shape so
// a future sprint can build on it without a breaking migration.
enum OrganizationKind {
  SCHOOL
  TRAINING_CENTER
  CORPORATE
}

enum OrgMemberRole {
  OWNER
  ADMIN
  TEACHER
  MEMBER
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  kind      OrganizationKind @default(SCHOOL)
  ownerId   String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  owner   User                 @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members OrganizationMember[]

  @@index([ownerId])
  @@map("organizations")
}

model OrganizationMember {
  id             String        @id @default(cuid())
  organizationId String
  userId         String
  role           OrgMemberRole @default(MEMBER)
  joinedAt       DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("OrganizationMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ─── Chapter content cache (Sprint BL — chapter learning workspace) ─────────
// Global cache (not per-user) for AI-generated chapter summaries/objectives,
// keyed by board+subject+grade+chapter+language so all students share results.

model ChapterContentCache {
  id          String   @id @default(cuid())
  board       String
  subjectSlug String
  grade       Int
  chapterId   String
  language    String   @default("en")
  summary     String
  objectives  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([board, subjectSlug, grade, chapterId, language])
  @@map("chapter_content_cache")
}

// Sprint CI: AI-generated revision notes / sheets, cached globally per
// board/subject/grade/chapter/noteType (same pattern as ChapterContentCache).
model RevisionNotesCache {
  id          String   @id @default(cuid())
  board       String
  subjectSlug String
  grade       Int
  chapterId   String
  noteType    String   // "quick" | "exam" | "formula"
  language    String   @default("en")
  content     Json     // structured RevisionNotes payload
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([board, subjectSlug, grade, chapterId, noteType, language])
  @@map("revision_notes_cache")
}
