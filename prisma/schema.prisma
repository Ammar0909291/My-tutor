generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth v5 required tables) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash        String?
  onboardingCompleted Boolean   @default(false)
  xpPoints            Int       @default(0)
  referralCode        String?   @unique
  referredBy          String?
  freeSessionsExtra   Int       @default(0)
  telegramChatId      String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts      Account[]
  sessions      AuthSession[]
  profile       Profile?
  learnSessions LearnSession[]
  subscription  Subscription?
  learningPaths LearningPath[]
  flashcards    Flashcard[]
  studentProgress StudentProgress[]
  referralsGiven  Referral[] @relation("referrer")
  weeklyXP        WeeklyXP[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Student Profile ──────────────────────────────────────────────────────────

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  selfDescription  String          @db.Text
  currentLevel     String?
  learningGoals    String?         @db.Text
  voiceId          String?
  teachingLanguage TeachingLanguage @default(en)
  confusedTopics    String[]  @default([])
  masteredTopics    String[]  @default([])
  totalSessions     Int       @default(0)
  totalMessages     Int       @default(0)
  lastStudiedTopic  String?
  streakDays        Int       @default(0)
  lastStudyDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects ProfileSubject[]

  @@map("profiles")
}

// ─── Subjects ─────────────────────────────────────────────────────────────────

model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  // c | cpp | python | english
  type        SubjectType
  description String? @db.Text

  profileSubjects ProfileSubject[]
  learnSessions   LearnSession[]
  learningPaths   LearningPath[]

  @@map("subjects")
}

model ProfileSubject {
  id        String   @id @default(cuid())
  profileId String
  subjectId String
  level     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([profileId, subjectId])
  @@map("profile_subjects")
}

// ─── Learning Path (Claude-generated curriculum) ─────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  title       String
  // Full JSON curriculum generated by Claude
  curriculum  Json
  currentStep Int      @default(0)
  totalSteps  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@map("learning_paths")
}

// ─── Learn Sessions ───────────────────────────────────────────────────────────

model LearnSession {
  id          String        @id @default(cuid())
  userId      String
  subjectId   String
  title       String?
  status      SessionStatus @default(ACTIVE)
  // Snapshot of context sent to Claude at session start
  contextSnapshot Json?
  // Detected mood/engagement level from Claude's analysis
  moodAnalysis    Json?
  summary     String?   @db.Text
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject  Subject   @relation(fields: [subjectId], references: [id])
  messages Message[]

  @@map("learn_sessions")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String      @db.Text
  // If voice: transcript + audio file reference
  audioUrl  String?
  // If code: language + snippet
  codeSnippet String?   @db.Text
  codeLanguage String?
  // Token usage for cost tracking
  inputTokens  Int?
  outputTokens Int?
  createdAt DateTime @default(now())

  session LearnSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  status               SubscriptionStatus @default(FREE)
  freeSessionUsed      Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Flashcards ───────────────────────────────────────────────────────────────

model Flashcard {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  question    String
  answer      String
  nextReview  DateTime @default(now())
  reviewCount Int      @default(0)
  easy        Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}

// ─── Structured Curriculum ───────────────────────────────────────────────────

model Curriculum {
  id          String   @id @default(cuid())
  subjectCode String   // 'c' | 'cpp' | 'python' | 'english'
  unit        Int
  unitTitle   String
  lesson      Int      // lesson number within unit
  lessonTitle String
  lessonGoal  String   @db.Text
  order       Int      // global order across all lessons in subject
  createdAt   DateTime @default(now())

  @@unique([subjectCode, order])
  @@index([subjectCode])
  @@map("curriculum")
}

model StudentProgress {
  id               String   @id @default(cuid())
  userId           String
  subjectCode      String
  currentLesson    Int      @default(1)
  completedLessons Int[]    @default([])
  lastStudiedAt    DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectCode])
  @@map("student_progress")
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id         String    @id @default(cuid())
  referrerId String
  referredId String?
  code       String    @unique
  used       Boolean   @default(false)
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  referrer User @relation("referrer", fields: [referrerId], references: [id])

  @@map("referrals")
}

// ─── Weekly XP (leaderboard) ──────────────────────────────────────────────────

model WeeklyXP {
  id     String @id @default(cuid())
  userId String
  week   String // "2026-W23"
  xp     Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, week])
  @@map("weekly_xp")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeachingLanguage {
  ru
  en
  hi
}

enum SubjectType {
  C
  CPP
  PYTHON
  ENGLISH
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}
