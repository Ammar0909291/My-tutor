// ─── YandexGPT usage monitoring + spending protection ────────────────────────
// Additive-only; logs every Yandex/Groq/fallback AI completion call so usage,
// cost, and provider health can be tracked without touching existing flows.

model YandexUsageLog {
  id               String     @id @default(cuid())
  userId           String?
  subject          String?
  teachingLanguage String
  provider         AIProvider
  requestTokens    Int        @default(0)
  responseTokens   Int        @default(0)
  estimatedCost    Float      @default(0)
  success          Boolean
  errorMessage     String?    @db.Text
  createdAt        DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([provider])
  @@map("yandex_usage_logs")
}

// Singleton row (id always "singleton") holding admin-configurable spending
// guardrails. When a limit is hit, the router skips Yandex and uses the
// fallback provider — lessons are never interrupted.
model AiUsageLimit {
  id                  String   @id @default("singleton")
  dailyRequestLimit   Int      @default(500)
  monthlyCostLimitUsd Float    @default(20)
  maxTokensPerRequest Int      @default(2000)
  updatedAt           DateTime @updatedAt

  @@map("ai_usage_limits")
}

enum AIProvider {
  YANDEX
  GROQ
  FALLBACK
}

// ─── Career Roadmaps + Certifications + Job Readiness (Sprint D) ─────────────
// Additive layer on top of Subject/ProfileSubject/ModuleProgress (Sprint B)
// and RetentionMetric/Project (Sprint C): a Roadmap bundles existing library
// subjects into a career outcome ("Backend Developer", "English Fluency"),
// auto-enrolls the learner in each one, tracks milestones as they progress,
// gates a capstone project at the end, and — on completion — issues a
// verifiable certificate plus rolls everything into a Job Readiness score.

model Roadmap {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  description      String   @db.Text
  outcome          String
  // Ordered SUBJECT_LIBRARY slugs the roadmap auto-enrolls the learner in.
  requiredSubjects String[] @default([])
  estimatedWeeks   Int      @default(12)
  createdAt        DateTime @default(now())

  enrollments  RoadmapEnrollment[]
  milestones   Milestone[]
  capstone     CapstoneProject?
  certificates Certificate[]

  @@map("roadmaps")
}

model RoadmapEnrollment {
  id          String        @id @default(cuid())
  userId      String
  roadmapId   String
  status      RoadmapStatus @default(ACTIVE)
  progressPct Int           @default(0)
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  updatedAt   DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap      Roadmap       @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  milestones   Milestone[]
  certificates Certificate[]

  @@unique([userId, roadmapId])
  @@index([userId, status])
  @@map("roadmap_enrollments")
}

enum RoadmapStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model Milestone {
  id           String        @id @default(cuid())
  enrollmentId String
  roadmapId    String
  userId       String
  kind         MilestoneKind
  title        String
  description  String        @db.Text
  achievedAt   DateTime?
  createdAt    DateTime      @default(now())

  enrollment RoadmapEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  roadmap    Roadmap           @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, kind, title])
  @@index([userId, achievedAt])
  @@map("milestones")
}

enum MilestoneKind {
  SUBJECT_COMPLETE
  ROADMAP_PROGRESS
  CAPSTONE_COMPLETE
  ROADMAP_COMPLETE
}

model CapstoneProject {
  id             String   @id @default(cuid())
  roadmapId      String   @unique
  slug           String
  title          String
  description    String   @db.Text
  requirements   String[] @default([])
  estimatedHours Int      @default(10)
  createdAt      DateTime @default(now())

  roadmap     Roadmap              @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  submissions CapstoneSubmission[]

  @@map("capstone_projects")
}

model CapstoneSubmission {
  id           String        @id @default(cuid())
  userId       String
  capstoneId   String
  status       ProjectStatus @default(NOT_STARTED)
  content      String?       @db.Text
  score        Int?
  aiReview     String?       @db.Text
  strengths    String[]      @default([])
  improvements String[]      @default([])
  completedAt  DateTime?
  updatedAt    DateTime      @updatedAt
  createdAt    DateTime      @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  capstone CapstoneProject @relation(fields: [capstoneId], references: [id], onDelete: Cascade)

  @@unique([userId, capstoneId])
  @@index([userId, status])
  @@map("capstone_submissions")
}

model Certificate {
  id              String   @id @default(cuid())
  certificateCode String   @unique
  userId          String
  roadmapId       String
  enrollmentId    String
  recipientName   String
  roadmapTitle    String
