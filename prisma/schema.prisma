generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth (NextAuth v5 required tables) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash        String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts      Account[]
  sessions      AuthSession[]
  profile       Profile?
  learnSessions LearnSession[]
  subscription  Subscription?
  learningPaths LearningPath[]

  // W1-2 (implements W0-ADR-10): Educational Brain student memory stores
  conceptMasteryRecords ConceptMasteryRecord[]
  activeMisconceptions  ActiveMisconception[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Student Profile ──────────────────────────────────────────────────────────

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  selfDescription  String          @db.Text
  currentLevel     String?
  learningGoals    String?         @db.Text
  voiceId          String?
  teachingLanguage TeachingLanguage @default(ru)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects ProfileSubject[]

  @@map("profiles")
}

// ─── Subjects ─────────────────────────────────────────────────────────────────

model Subject {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  // c | cpp | python | english
  type        SubjectType
  description String? @db.Text

  profileSubjects ProfileSubject[]
  learnSessions   LearnSession[]
  learningPaths   LearningPath[]

  @@map("subjects")
}

model ProfileSubject {
  id        String   @id @default(cuid())
  profileId String
  subjectId String
  level     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([profileId, subjectId])
  @@map("profile_subjects")
}

// ─── Learning Path (Claude-generated curriculum) ─────────────────────────────

model LearningPath {
  id          String   @id @default(cuid())
  userId      String
  subjectId   String
  title       String
  // Full JSON curriculum generated by Claude
  curriculum  Json
  currentStep Int      @default(0)
  totalSteps  Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])

  @@map("learning_paths")
}

// ─── Learn Sessions ───────────────────────────────────────────────────────────

model LearnSession {
  id          String        @id @default(cuid())
  userId      String
  subjectId   String
  title       String?
  status      SessionStatus @default(ACTIVE)
  // Snapshot of context sent to Claude at session start
  contextSnapshot Json?
  // Detected mood/engagement level from Claude's analysis
  moodAnalysis    Json?
  summary     String?   @db.Text
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  updatedAt   DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject  Subject   @relation(fields: [subjectId], references: [id])
  messages Message[]

  @@map("learn_sessions")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id        String      @id @default(cuid())
  sessionId String
  role      MessageRole
  content   String      @db.Text
  // If voice: transcript + audio file reference
  audioUrl  String?
  // If code: language + snippet
  codeSnippet String?   @db.Text
  codeLanguage String?
  // Token usage for cost tracking
  inputTokens  Int?
  outputTokens Int?
  createdAt DateTime @default(now())

  session LearnSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("messages")
}

// ─── Subscription ─────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  status               SubscriptionStatus @default(FREE)
  freeSessionUsed      Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TeachingLanguage {
  ru
  en
  hi
}

enum SubjectType {
  C
  CPP
  PYTHON
  ENGLISH
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── Educational Brain — Student Memory (W1-2, implements ADR 10 Phase 1) ────
// Additive only: no existing table above is touched. Nothing reads or writes
// these tables yet (Wave 2 wires the readers/writers per ADR 10 §10).

// Canonical mastery classification (ADR 07 + ADR 10).
// Single source of truth: the Persist stage of the chat-route pipeline.
enum MasteryLevel {
  NOT_STARTED
  INTRODUCED
  DEVELOPING
  PROFICIENT
  MASTERED
}

// Per-(user, concept) mastery record — replaces the scattered masteryPct reads
// that currently happen against TopicProgress (added in later sprints).
// The two scores are never conflated: masteryScore is the best score achieved,
// decayedScore is current retention after the forgetting curve is applied.
model ConceptMasteryRecord {
  userId            String
  conceptId         String       // KG node slug, e.g. "math.algebra.linear_equations"

  masteryScore      Float        @default(0)    // 0–1, best score achieved
  decayedScore      Float        @default(0)    // 0–1, current retention (masteryScore × decay)
  masteryConfidence Float        @default(0)    // 0–1, statistical confidence in the score
  masteryLevel      MasteryLevel @default(NOT_STARTED)  // canonical enum

  lastProbeOutcome  String?      // "pass" | "fail" | "partial"
  lastSeenAt        DateTime     @default(now())
  attemptCount      Int          @default(0)
  sampleSize        Int          @default(0)    // effective # of graded interactions
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, conceptId])
  @@index([userId, masteryLevel])
  @@index([userId, decayedScore])
  @@map("concept_mastery_records")
}

// Versioned policy store: formalises hardcoded Teaching Brain constants into
// named, auditable, experiment-capable config rows (ADR 10 §4.4 / ADR 05).
// Read-only at runtime — no teaching-path code may write to this table.
model BrainConfig {
  id            String    @id
  name          String    @unique  // e.g. "mastery_thresholds", "probe_target_frequency"
  value         Json                // typed payload varies by name
  version       Int       @default(1)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  changedBy     String?
  reason        String?   @db.Text

  @@index([name, effectiveFrom])
  @@map("brain_config")
}

// Active misconception confidence — Bayesian update per detection/repair event.
// Replaces the count-based heuristic (LOW=2, MEDIUM=3-4, HIGH=5+ occurrences)
// used today in the misconception signal block.
enum MisconceptionStatus {
  ACTIVE
  REPAIR_IN_PROGRESS
  REPAIRED
  ESCALATED
}

model ActiveMisconception {
  userId          String
  misconceptionId String              // canonical slug, e.g. "math.add.carrying_error"
  topicSlug       String              // KG node slug the misconception applies to
  confidence      Float               @default(0.5)  // 0–1, Bayesian posterior
  firstDetectedAt DateTime            @default(now())
  lastDetectedAt  DateTime            @default(now())
  repairAttempts  Int                 @default(0)
  lastRepairAt    DateTime?
  status          MisconceptionStatus @default(ACTIVE)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, misconceptionId])
  @@index([userId, status])
  @@index([userId, topicSlug])
  @@map("active_misconceptions")
}

// ─── Evidence Engine (W1-3, implements ADR 13 Phase 1) ───────────────────────
// Append-only event log. Single writer: the Persist stage of the chat-route.
// No FK to User — denormalized intentionally for lock-free INSERT performance
// on the hot path (ADR 13 §5 Design C, §10 Phase 1 spec).

enum EvidenceCategory {
  ASSET_SHOWN          // strength always 0.0 — consumed-ness, not effectiveness
  PROBE_OUTCOME        // strength: 1.0 pass / 0.0 fail / 0.5 partial
  MISCONCEPTION_DETECTED
  LEARNER_FEEDBACK
  RE_ASK
  SUMMATIVE_OUTCOME
}

enum GradeBand {
  EARLY              // grades K-2 / ages 5-7
  ELEMENTARY         // grades 3-5 / ages 8-10
  MIDDLE             // grades 6-8 / ages 11-13
  HIGH               // grades 9-12 / ages 14-17
  UNDERGRADUATE
  ADULT
}

model EvidenceEvent {
  eventId        String          @id @default(uuid())
  occurredAt     DateTime        @default(now())

  // Denormalized — no FK, lock-free INSERT on hot path
  userId         String
  sessionId      String?
  turnId         String?         // assistant Message.id, set when available

  conceptId      String          // KG node slug (Phase 1: subject slug proxy)
  language       String          // BCP-47, e.g. "ru", "en"
  gradeBand      GradeBand

  category       EvidenceCategory
  assetId        String?         // Knowledge Asset id (Phase 3+)
  misconceptionId String?        // canonical misconception slug
  curriculumId   String?         // board/chapter/topic composite key

  outcome        String          // "pass" | "fail" | "partial" | "shown" | etc.
  strength       Float           // 0–1 signal weight per category spec
  rawScore       Float?          // raw probe score when applicable
  contextHash    String?         // hash of turn context for deduplication

  @@index([userId, conceptId])
  @@index([userId, occurredAt])
  @@index([sessionId, occurredAt])
  @@index([conceptId, category])
  @@map("evidence_events")
}
