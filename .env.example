# ─── Database ────────────────────────────────────────────────────────────────
# IMPORTANT (Supabase + Vercel — current production provider): Supabase's
# *direct* connection host (db.<ref>.supabase.co) is IPv6-only. Vercel's
# serverless/edge functions egress over IPv4 only, so DATABASE_URL pointing
# at the direct host fails with "Can't reach database server" in production
# even though it works locally over IPv6. Always use the pooler host
# (IPv4-compatible) instead — copy both URLs from Supabase Dashboard ->
# Project Settings -> Database -> Connection string -> ORM:
#   DATABASE_URL = transaction-mode pooler, port 6543, ?pgbouncer=true
#                  (used at runtime by the app)
#   DIRECT_URL   = session-mode pooler, port 5432
#                  (used by `prisma migrate`/`db push`, needs schema.prisma's
#                  `directUrl` — see prisma/schema.prisma)
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>.pooler.supabase.com:5432/postgres"

# For Neon (alternative provider): DATABASE_URL = pooled URL (prevents
# cold-start timeouts on serverless); DIRECT_URL = direct URL (used only by
# prisma db push/migrate). Get both from console.neon.tech → Connection
# Details → toggle Pooled connection. Recommended params on the pooled URL
# to survive Neon auto-suspend: ?sslmode=require&connection_limit=1&pool_timeout=20
# DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require&connection_limit=1&pool_timeout=20"
# DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"
# Vercel/Neon integration aliases (optional — mirror DATABASE_URL):
#   POSTGRES_PRISMA_URL      = pooled URL with ?pgbouncer=true&connect_timeout=15
#   POSTGRES_URL_NON_POOLING = direct URL with no extra params
# POSTGRES_PRISMA_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?pgbouncer=true&connect_timeout=15"
# POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"
# For local Postgres: set both to the same value (no ?pgbouncer params needed)
# DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"
# DIRECT_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET (single underscore), NOT AUTH__SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Groq (AI + TTS + STT — required, free tier at console.groq.com) ────────
GROQ_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
REDIS_URL=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── Cron (Vercel cron jobs — generate: openssl rand -hex 32) ────────────────
CRON_SECRET=""

# ─── Telegram Bot (optional — study reminders via Telegram) ──────────────────
TELEGRAM_BOT_TOKEN=""
# Secret token passed to Telegram setWebhook (secret_token param); the webhook
# rejects requests whose X-Telegram-Bot-Api-Secret-Token header doesn't match.
TELEGRAM_WEBHOOK_SECRET=""

# ─── Monitoring (optional — strongly recommended in production) ──────────────
# Sentry DSN from sentry.io → Project Settings → Client Keys. When unset,
# error reporting is a no-op. Free tier (5k events/month) is sufficient.
SENTRY_DSN=""
# Optional: POST errors to Sentry/Logtail/Slack webhook
MONITORING_WEBHOOK_URL=""

# Global AI requests-per-minute budget across ALL users (protects the Groq
# org quota; free tier ≈ 30/min). 0 or unset = disabled.
AI_GLOBAL_RPM=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin (comma-separated email addresses with access to analytics center) ──
ADMIN_EMAILS=""

# ─── Yandex Cloud (Russia region only) ───────────────────────────────────────
# Get from console.cloud.yandex.ru → IAM → Service accounts → Create key
# Without these, Russian students fall back to Groq automatically
# App works fine without Yandex — it's an upgrade not a requirement
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# ─── Sarvam AI (Hindi text-to-speech, Bulbul v3) ─────────────────────────────
# Get from dashboard.sarvam.ai. Used only when teachingLanguage === 'hi'.
# Without this, Hindi students fall back to Groq TTS automatically.
# App works fine without Sarvam — it's an upgrade not a requirement.
SARVAM_API_KEY=

# ─── Educational Brain pipeline (default OFF — optional analytics layer) ─────
# When true, each tutor turn runs a 5-stage fire-and-forget pipeline that
# frames intent, retrieves KG context, and persists a TurnContext record.
# Zero overhead when absent or false — safe to leave unset in development.
# Requires EbConcept / EbModule tables populated first:
#   npm run seed:eb-physics   (physics seed — run after prisma db push)
ENABLE_EDUCATIONAL_BRAIN_PIPELINE=

# ─── Part 2 scene generation (independent flags) ──────────────────────────────
# ENABLE_PARAMETRIC_SCENE_GENERATION: 15 textbook-standard, parameter-driven
# scene types (projectile/triangle/molecule/vector/circular/pendulum/electron
# shells/crystal lattice/1D collision/ray optics/historical timeline/economics
# curves/calculus graph/civics org chart/electric circuit) — LLM extracts
# parameters only, deterministic code computes geometry. See
# src/lib/teaching/sceneGenerators/. ON by default — enabled in production,
# wired into src/app/api/learn/chat/route.ts behind this flag.
ENABLE_PARAMETRIC_SCENE_GENERATION=true
# ENABLE_AI_SCENE_GENERATION: the older free-form generator (LLM generates
# raw scene coordinates). Proven unreliable on easy cases in feasibility
# testing — keep OFF; superseded by ENABLE_PARAMETRIC_SCENE_GENERATION above.
ENABLE_AI_SCENE_GENERATION=
# ENABLE_DYNAMIC_VISUALIZATION: wide-coverage 3D Three.js (with a 2D recharts
# fallback) visualization engine — generates a React component from the
# explanation text and renders it inside a sandboxed iframe. Fires ONLY when
# none of the deterministic VisualSpec / parametric SceneSpec pipelines
# produced anything for the turn, so it never overrides a trusted visual.
# Costs one Groq call per uncached concept (cached per concept globally).
# ON by default — flip OFF if you don't want the dynamic engine to run.
ENABLE_DYNAMIC_VISUALIZATION=true
