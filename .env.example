# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter (AI tutor — free models at openrouter.ai) ───────────────────
OPENROUTER_API_KEY=""

# ─── OpenAI (Whisper) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── ElevenLabs (TTS) ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=""
# Default voice ID — used for the "Alexei" tutor character (get IDs from elevenlabs.io/voice-library)
ELEVENLABS_VOICE_ID="pNInz6obpgDQGcFmaJgB"
# Optional: distinct voices for Maria and Dmitry characters; falls back to ELEVENLABS_VOICE_ID
ELEVENLABS_VOICE_MARIA_ID=""
ELEVENLABS_VOICE_DMITRY_ID=""

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
