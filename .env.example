# ─── Database ────────────────────────────────────────────────────────────────
# For Vercel + Neon/Supabase: use the pooled connection URL
DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET, NOT NEXTAUTH_SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
# For local dev only — omit on Vercel (it uses VERCEL_URL automatically)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter (primary AI — free models at openrouter.ai) ──────────────────
OPENROUTER_API_KEY=""

# ─── Gemini (AI fallback — used when all OpenRouter models are rate-limited) ──
GEMINI_API_KEY=""

# ─── OpenAI (optional — Whisper STT) ─────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
# For Vercel: use Upstash Redis (free tier at upstash.com)
REDIS_URL=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Monitoring (optional — external error webhook for ops alerts) ─────────────
# Sentry/Logtail/Slack-compatible POST endpoint. Receives redacted error
# payloads only — never credentials. Leave blank to log to stderr only.
MONITORING_WEBHOOK_URL=""
