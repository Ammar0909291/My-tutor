# ─── Database ────────────────────────────────────────────────────────────────
# For Vercel + Neon/Supabase: use the pooled connection URL here
DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
# On Vercel: do NOT set NEXTAUTH_URL — Vercel sets VERCEL_URL automatically.
# For local dev only:
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter (AI tutor) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=""

# ─── Gemini (AI fallback — used when all OpenRouter models are rate-limited) ──
GEMINI_API_KEY=""

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
# For Vercel: use Upstash Redis (free tier available at upstash.com)
REDIS_URL=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
