# ─── Database ────────────────────────────────────────────────────────────────
# For Neon: DATABASE_URL = pooled URL (prevents cold-start timeouts on serverless)
#           DIRECT_URL   = direct URL (used only by prisma db push/migrate)
# Get both from console.neon.tech → Connection Details → toggle Pooled connection
#
# Recommended params on the pooled URL to survive Neon auto-suspend:
#   ?sslmode=require&connection_limit=1&pool_timeout=20
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?sslmode=require&connection_limit=1&pool_timeout=20"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"
# Vercel/Neon integration aliases (optional — mirror DATABASE_URL):
#   POSTGRES_PRISMA_URL      = pooled URL with ?pgbouncer=true&connect_timeout=15
#   POSTGRES_URL_NON_POOLING = direct URL with no extra params
POSTGRES_PRISMA_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"
# For local Postgres: set both to the same value (no ?pgbouncer params needed)
# DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"
# DIRECT_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET (single underscore), NOT AUTH__SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Groq (AI + TTS + STT — required, free tier at console.groq.com) ────────
GROQ_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
REDIS_URL=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── Cron (Vercel cron jobs — generate: openssl rand -hex 32) ────────────────
CRON_SECRET=""

# ─── Telegram Bot (optional — study reminders via Telegram) ──────────────────
TELEGRAM_BOT_TOKEN=""
# Secret token passed to Telegram setWebhook (secret_token param); the webhook
# rejects requests whose X-Telegram-Bot-Api-Secret-Token header doesn't match.
TELEGRAM_WEBHOOK_SECRET=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin (comma-separated email addresses with access to analytics center) ──
ADMIN_EMAILS=""

# ─── Yandex Cloud (Russia region only) ───────────────────────────────────────
# Get from console.cloud.yandex.ru → IAM → Service accounts → Create key
# Without these, Russian students fall back to Groq automatically
# App works fine without Yandex — it's an upgrade not a requirement
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
