# ─── Database ────────────────────────────────────────────────────────────────
# IMPORTANT (Supabase + Vercel): Supabase's *direct* connection host
# (db.<ref>.supabase.co) is IPv6-only. Vercel's serverless/edge functions
# egress over IPv4 only, so DATABASE_URL pointing at the direct host fails
# with "Can't reach database server" in production even though it works
# locally over IPv6. Always use the pooler host (IPv4-compatible) instead —
# copy both URLs from Supabase Dashboard -> Project Settings -> Database ->
# Connection string -> ORM:
#   DATABASE_URL = transaction-mode pooler, port 6543, ?pgbouncer=true
#                  (used at runtime by the app)
#   DIRECT_URL   = session-mode pooler, port 5432
#                  (used by `prisma migrate`/`db push`, needs schema.prisma's
#                  `directUrl` — see prisma/schema.prisma)
DATABASE_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@<pooler-host>.pooler.supabase.com:5432/postgres"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET, NOT NEXTAUTH_SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
# For local dev only — omit on Vercel (it uses VERCEL_URL automatically)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OpenRouter (primary AI — free models at openrouter.ai) ──────────────────
OPENROUTER_API_KEY=""

# ─── Gemini (AI fallback — used when all OpenRouter models are rate-limited) ──
GEMINI_API_KEY=""

# ─── OpenAI (optional — Whisper STT) ─────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
# For Vercel: use Upstash Redis (free tier at upstash.com)
REDIS_URL=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
