# ─── Database ────────────────────────────────────────────────────────────────
# For Neon: DATABASE_URL = pooled URL (prevents cold-start timeouts on serverless)
#           DIRECT_URL   = direct URL (used only by prisma db push/migrate)
# Get both from console.neon.tech → Connection Details → toggle Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/neondb?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech:5432/neondb"
# For local Postgres: set both to the same value (no ?pgbouncer params needed)
# DATABASE_URL="postgresql://user:password@localhost:5432/my_tutor"
# DIRECT_URL="postgresql://user:password@localhost:5432/my_tutor"

# ─── NextAuth v5 ─────────────────────────────────────────────────────────────
# IMPORTANT: NextAuth v5 uses AUTH_SECRET, NOT NEXTAUTH_SECRET
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-generated-secret"
# For local dev only — omit on Vercel (it uses VERCEL_URL automatically)
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Groq (primary AI — fast inference, free tier at console.groq.com) ──────
GROQ_API_KEY=""

# ─── Gemini (AI fallback — used when Groq is rate-limited) ──────────────────
GEMINI_API_KEY=""

# ─── OpenRouter (legacy — no longer used as primary) ─────────────────────────
OPENROUTER_API_KEY=""

# ─── OpenAI (optional — Whisper STT) ─────────────────────────────────────────
OPENAI_API_KEY=""

# ─── Redis (optional — app works without it) ──────────────────────────────────
# For Vercel: use Upstash Redis (free tier at upstash.com)
REDIS_URL=""

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_ID=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── Email / SMTP (for password reset) ────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="My Tutor <noreply@mytutor.app>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
